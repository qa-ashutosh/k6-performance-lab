# .env.example
# Copy this file to .env and fill in your actual values.
# .env is gitignored — never commit real tokens to the repo.
#
# Usage:
#   cp .env.example .env
#   then edit .env with your real values
#   then run: ./run-tests.sh tests/smoke-test.js

# Base URL of the application under test
BASE_URL=http://localhost:3333

# Auth token for QuickPizza /api/pizza endpoint
# Get this from the QuickPizza UI after starting Docker stack:
# 1. Open http://localhost:3333
# 2. Click the top-right user icon
# 3. Copy the token shown
AUTH_TOKEN=your_token_here

# Optional overrides
TARGET_VUS=50
DURATION=5m
